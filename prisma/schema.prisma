  @@index([buildingId])
  @@map("floors")
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(200)
  nameEn    String   @map("name_en") @db.VarChar(200)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  floorDepartments                 FloorDepartment[]
  staff                            Staff[]
  appointments                     Appointment[]
  visitRecords                     VisitRecord[]
  visitEntries                     VisitEntry[]
  visitPurposeDepartmentRules      VisitPurposeDepartmentRule[]
  approverGroups                   ApproverGroup[]
  departmentAccessMapping          DepartmentAccessMapping?
  departmentAdditionalAccessGroups DepartmentAdditionalAccessGroup[]
  reportDepartmentStats            ReportDepartmentStat[]
  appointmentGroups                AppointmentGroup[]

  @@map("departments")
}

model FloorDepartment {
  floorId      Int @map("floor_id")
  departmentId Int @map("department_id")

  // Relations
  floor      Floor      @relation(fields: [floorId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@id([floorId, departmentId])
  @@index([departmentId])
  @@map("floor_departments")
}

