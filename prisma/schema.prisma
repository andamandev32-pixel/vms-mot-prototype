model VisitPurpose {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(100)
  nameEn            String   @map("name_en") @db.VarChar(100)
  icon              String?  @db.VarChar(10)
  isActive          Boolean  @default(true) @map("is_active")
  showOnLine        Boolean  @default(true) @map("show_on_line")
  showOnWeb         Boolean  @default(true) @map("show_on_web")
  showOnKiosk       Boolean  @default(true) @map("show_on_kiosk")
  showOnCounter     Boolean  @default(true) @map("show_on_counter")
  allowedEntryModes String   @default("single") @map("allowed_entry_modes") @db.VarChar(50)
  sortOrder         Int      @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  departmentRules       VisitPurposeDepartmentRule[]
  channelConfigs        VisitPurposeChannelConfig[]
  appointments          Appointment[]
  visitRecords          VisitRecord[]
  approverGroupPurposes ApproverGroupPurpose[]
  servicePointPurposes  ServicePointPurpose[]
  purposeSlipMappings   PurposeSlipMapping[]
  appointmentGroups     AppointmentGroup[]

  @@index([isActive])
  @@map("visit_purposes")
}

model VisitPurposeDepartmentRule {
  id                Int     @id @default(autoincrement())
  visitPurposeId    Int     @map("visit_purpose_id")
  departmentId      Int     @map("department_id")
  requirePersonName Boolean @default(false) @map("require_person_name")
  requireApproval   Boolean @default(false) @map("require_approval")
  approverGroupId   Int?    @map("approver_group_id")
  offerWifi         Boolean @default(false) @map("offer_wifi")
  acceptFromLine    Boolean @default(true) @map("accept_from_line")
  acceptFromWeb     Boolean @default(true) @map("accept_from_web")
  acceptFromKiosk   Boolean @default(true) @map("accept_from_kiosk")
  acceptFromCounter Boolean @default(true) @map("accept_from_counter")
  followBusinessHours Boolean @default(false) @map("follow_business_hours")
  isActive          Boolean @default(true) @map("is_active")

  // Relations
  visitPurpose  VisitPurpose   @relation(fields: [visitPurposeId], references: [id])
  department    Department     @relation(fields: [departmentId], references: [id])
  approverGroup ApproverGroup? @relation(fields: [approverGroupId], references: [id])

  @@index([visitPurposeId])
  @@index([departmentId])
  @@index([approverGroupId])
  @@map("visit_purpose_department_rules")
}

model VisitPurposeChannelConfig {
  id             Int     @id @default(autoincrement())
  visitPurposeId Int     @map("visit_purpose_id")
  channel        String  @db.VarChar(20)
  requirePhoto   Boolean @default(false) @map("require_photo")

  // Relations
  visitPurpose     VisitPurpose                  @relation(fields: [visitPurposeId], references: [id])
