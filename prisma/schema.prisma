model AppointmentGroup {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(200)
  nameEn           String?   @map("name_en") @db.VarChar(200)
  description      String?   @db.Text
  visitPurposeId   Int       @map("visit_purpose_id")
  departmentId     Int       @map("department_id")
  hostStaffId      Int?      @map("host_staff_id")
  entryMode        String    @default("single") @map("entry_mode") @db.VarChar(20)
  dateStart        DateTime  @map("date_start") @db.Date
  dateEnd          DateTime? @map("date_end") @db.Date
  timeStart        DateTime  @map("time_start") @db.Time(0)
  timeEnd          DateTime  @map("time_end") @db.Time(0)
  room             String?   @db.VarChar(50)
  building         String?   @db.VarChar(100)
  floor            String?   @db.VarChar(20)
  totalExpected    Int       @default(0) @map("total_expected")
  notifyOnCheckin  Boolean   @default(false) @map("notify_on_checkin")
  approverGroupId  Int?      @map("approver_group_id")
  sendVisitorEmail Boolean   @default(false) @map("send_visitor_email")
  staffNotifyConfig String?  @map("staff_notify_config") @db.Text
  createdByStaffId Int       @map("created_by_staff_id")
  status           String    @default("active") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  visitPurpose   VisitPurpose                  @relation(fields: [visitPurposeId], references: [id])
  department     Department                    @relation(fields: [departmentId], references: [id])
  hostStaff      Staff?                        @relation("GroupHost", fields: [hostStaffId], references: [id])
  createdByStaff Staff                         @relation("GroupCreatedBy", fields: [createdByStaffId], references: [id])
  approverGroup  ApproverGroup?                @relation(fields: [approverGroupId], references: [id])
  appointments   Appointment[]
  daySchedules   AppointmentGroupDaySchedule[]

  @@index([createdByStaffId])
  @@index([dateStart])
  @@index([status])
  @@index([approverGroupId])
  @@map("appointment_groups")
}

model AppointmentGroupDaySchedule {
  id        Int      @id @default(autoincrement())
  groupId   Int      @map("group_id")
  date      DateTime @db.Date
  timeStart DateTime @map("time_start") @db.Time(0)
  timeEnd   DateTime @map("time_end") @db.Time(0)
  notes     String?  @db.VarChar(200)

  // Relations
  group AppointmentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, date])
  @@index([groupId])
  @@index([date])
  @@map("appointment_group_day_schedules")
}

