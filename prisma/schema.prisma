// PDPA
// ════════════════════════════════════════════════════

model PdpaConsentConfig {
  id              Int      @id @default(autoincrement())
  textTh          String   @map("text_th") @db.Text
  textEn          String   @map("text_en") @db.Text
  retentionDays   Int      @default(90) @map("retention_days")
  requireScroll   Boolean  @default(true) @map("require_scroll")
  displayChannels Json     @map("display_channels")
  isActive        Boolean  @default(true) @map("is_active")
  version         Int      @default(1)
  updatedBy       Int?     @map("updated_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  updatedByStaff Staff?               @relation("PdpaConsentConfigUpdatedBy", fields: [updatedBy], references: [id])
  versions       PdpaConsentVersion[]

  @@map("pdpa_consent_configs")
}

model PdpaConsentVersion {
  id              Int      @id @default(autoincrement())
  configId        Int      @map("config_id")
  version         Int
  textTh          String   @map("text_th") @db.Text
  textEn          String   @map("text_en") @db.Text
  retentionDays   Int      @map("retention_days")
  requireScroll   Boolean  @default(true) @map("require_scroll")
  displayChannels Json     @map("display_channels")
  isActive        Boolean  @default(false) @map("is_active")
  effectiveDate   DateTime @map("effective_date") @db.Date
  changedBy       Int?     @map("changed_by")
  changeNote      String?  @map("change_note") @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  config         PdpaConsentConfig @relation(fields: [configId], references: [id])
  changedByStaff Staff?            @relation("PdpaConsentVersionChangedBy", fields: [changedBy], references: [id])

  @@index([configId])
  @@index([version])
  @@map("pdpa_consent_versions")
}

model PdpaConsentLog {
  id             Int      @id @default(autoincrement())
  visitorId      Int      @map("visitor_id")
  configVersion  Int      @map("config_version")
  consentChannel String   @map("consent_channel") @db.VarChar(20)
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  deviceId       String?  @map("device_id") @db.VarChar(100)
  consentedAt    DateTime @default(now()) @map("consented_at")
  expiresAt      DateTime @map("expires_at")

  // Relations
  visitor Visitor @relation(fields: [visitorId], references: [id])

  @@index([visitorId])
  @@index([consentChannel])
  @@index([consentedAt])
  @@map("pdpa_consent_logs")
}

// ════════════════════════════════════════════════════
// Reports & Logs
// ════════════════════════════════════════════════════

model Blocklist {
  id         Int       @id @default(autoincrement())
  firstName  String    @map("first_name") @db.VarChar(100)
  lastName   String    @map("last_name") @db.VarChar(100)
  company    String?   @db.VarChar(200)
  visitorId  Int?      @map("visitor_id")
  reason     String    @db.Text
  type       String    @db.VarChar(20)
  expiryDate DateTime? @map("expiry_date") @db.Date
  addedBy    Int       @map("added_by")
  addedAt    DateTime  @default(now()) @map("added_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  isActive   Boolean   @default(true) @map("is_active")

  // Relations
  visitor      Visitor?            @relation(fields: [visitorId], references: [id])
  addedByStaff Staff               @relation("BlocklistAddedBy", fields: [addedBy], references: [id])
  checkLogs    BlocklistCheckLog[]

  @@index([visitorId])
  @@index([isActive])
  @@index([type])
  @@index([firstName, lastName])
  @@map("blocklist")
}

model BlocklistCheckLog {
  id           Int      @id @default(autoincrement())
  blocklistId  Int      @map("blocklist_id")
  matchedName  String   @map("matched_name") @db.VarChar(200)
  checkChannel String   @map("check_channel") @db.VarChar(20)
  actionTaken  String   @map("action_taken") @db.VarChar(30)
  checkedAt    DateTime @default(now()) @map("checked_at")
  checkedBy    Int?     @map("checked_by")

  // Relations
  blocklist      Blocklist @relation(fields: [blocklistId], references: [id])
  checkedByStaff Staff?    @relation("BlocklistCheckLogCheckedBy", fields: [checkedBy], references: [id])

  @@index([blocklistId])
  @@index([checkedAt])
  @@map("blocklist_check_logs")
}

model ReportDailySummary {
  id                  Int      @id @default(autoincrement())
  date                DateTime @unique @db.Date
  totalVisitors       Int      @default(0) @map("total_visitors")
  totalAppointments   Int      @default(0) @map("total_appointments")
  walkinCount         Int      @default(0) @map("walkin_count")
  checkedIn           Int      @default(0) @map("checked_in")
  checkedOut          Int      @default(0) @map("checked_out")
  overstayCount       Int      @default(0) @map("overstay_count")
  avgVisitDurationMin Int?     @map("avg_visit_duration_min")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("report_daily_summary")
}

model ReportDepartmentStat {
  id               Int      @id @default(autoincrement())
  date             DateTime @db.Date
  departmentId     Int      @map("department_id")
  departmentName   String   @map("department_name") @db.VarChar(100)
  visitorCount     Int      @default(0) @map("visitor_count")
  appointmentCount Int      @default(0) @map("appointment_count")

  // Relations
  department Department @relation(fields: [departmentId], references: [id])

  @@index([date])
  @@index([departmentId])
  @@map("report_department_stats")
}

model ReportVisitTypeStat {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date
  visitType    String   @map("visit_type") @db.VarChar(30)
  visitorCount Int      @default(0) @map("visitor_count")

  @@index([date])
  @@index([visitType])
  @@map("report_visit_type_stats")
}
