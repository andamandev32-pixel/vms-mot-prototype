  // Relations
  channelConfig        VisitPurposeChannelConfig @relation(fields: [channelConfigId], references: [id])
  identityDocumentType IdentityDocumentType      @relation(fields: [identityDocumentTypeId], references: [id])

  @@id([channelConfigId, identityDocumentTypeId])
  @@index([identityDocumentTypeId])
  @@map("visit_purpose_channel_documents")
}

model PurposeSlipMapping {
  visitPurposeId Int  @id @map("visit_purpose_id")
  slipTemplateId Int? @map("slip_template_id")

  // Relations
  visitPurpose VisitPurpose       @relation(fields: [visitPurposeId], references: [id])
  slipTemplate VisitSlipTemplate? @relation(fields: [slipTemplateId], references: [id])

  @@index([slipTemplateId])
  @@map("purpose_slip_mappings")
}

// ════════════════════════════════════════════════════
// Locations
