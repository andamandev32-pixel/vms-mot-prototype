// ===== eVMS (Visitor Management System) Prisma Schema =====
// Generated from database-schema.ts — 57 tables
// Provider: MySQL (MariaDB compatible)

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════
// Auth & Users
// ════════════════════════════════════════════════════

model UserAccount {
  id                Int       @id @default(autoincrement())
  username          String?   @unique @map("username") @db.VarChar(50)
  email             String    @unique @db.VarChar(100)
  passwordHash      String    @map("password_hash") @db.VarChar(255)
  userType          String    @map("user_type") @db.VarChar(20)
  role              String    @db.VarChar(20)
  refId             Int?      @map("ref_id")
  firstName         String    @map("first_name") @db.VarChar(100)
  lastName          String    @map("last_name") @db.VarChar(100)
  phone             String?   @db.VarChar(20)
  isActive          Boolean   @default(true) @map("is_active")
  isEmailVerified   Boolean   @default(false) @map("is_email_verified")
  lineUserId        String?   @unique @map("line_user_id") @db.VarChar(50)
  lineDisplayName   String?   @map("line_display_name") @db.VarChar(100)
  lineLinkedAt      DateTime? @map("line_linked_at")
  resetToken        String?   @map("reset_token") @db.VarChar(255)
  resetTokenExpires DateTime? @map("reset_token_expires")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  systemSettingsUpdated    SystemSetting[]    @relation("SystemSettingUpdatedBy")
  lineFlexTemplatesUpdated LineFlexTemplate[] @relation("LineFlexTemplateUpdatedBy")
  kioskDevicesRegistered   KioskDevice[]      @relation("KioskDeviceRegisteredBy")

  @@index([role])
  @@index([userType])
  @@index([isActive])
  @@map("user_accounts")
}

model RolePermission {
  id        Int     @id @default(autoincrement())
  role      String  @db.VarChar(20)
  resource  String  @db.VarChar(50)
  action    String  @db.VarChar(20)
  scope     String  @default("own") @db.VarChar(20)
  isAllowed Boolean @default(true) @map("is_allowed")

  @@index([role])
  @@index([resource])
  @@map("role_permissions")
}

// ════════════════════════════════════════════════════
// Core Visitor / Appointment
// ════════════════════════════════════════════════════

model Visitor {
  id              Int       @id @default(autoincrement())
  firstName       String    @map("first_name") @db.VarChar(100)
  lastName        String    @map("last_name") @db.VarChar(100)
  firstNameEn     String?   @map("first_name_en") @db.VarChar(100)
  lastNameEn      String?   @map("last_name_en") @db.VarChar(100)
  name            String    @db.VarChar(200)
  nameEn          String?   @map("name_en") @db.VarChar(200)
  idNumber        String    @map("id_number") @db.VarChar(20)
  idType          String    @map("id_type") @db.VarChar(30)
  company         String?   @db.VarChar(150)
  phone           String    @db.VarChar(20)
  email           String?   @db.VarChar(100)
  lineUserId      String?   @unique @map("line_user_id") @db.VarChar(50)
  lineDisplayName String?   @map("line_display_name") @db.VarChar(100)
  lineLinkedAt    DateTime? @map("line_linked_at")
  photo           String?   @db.VarChar(255)
  nationality     String?   @db.VarChar(50)
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  registeredChannel String? @map("registered_channel") @db.VarChar(20)
  lastLoginAt     DateTime? @map("last_login_at")
  isBlocked       Boolean   @default(false) @map("is_blocked")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  appointments    Appointment[]
  visitRecords    VisitRecord[]
  visitEntries    VisitEntry[]
  pdpaConsentLogs PdpaConsentLog[]
  blocklists      Blocklist[]

  @@index([idNumber])
  @@index([phone])
  @@index([isBlocked])
  @@map("visitors")
}

model Appointment {
  id               Int       @id @default(autoincrement())
  bookingCode      String    @unique @map("booking_code") @db.VarChar(30)
  visitorId        Int       @map("visitor_id")
  hostStaffId      Int?      @map("host_staff_id")
  visitPurposeId   Int       @map("visit_purpose_id")
  departmentId     Int       @map("department_id")
  type             String    @db.VarChar(30)
  status           String    @default("pending") @db.VarChar(30)
  entryMode        String    @default("single") @map("entry_mode") @db.VarChar(20)
  dateStart        DateTime  @map("date_start") @db.Date
  dateEnd          DateTime? @map("date_end") @db.Date
  timeStart        DateTime  @map("time_start") @db.Time(0)
  timeEnd          DateTime  @map("time_end") @db.Time(0)
  purpose          String    @db.VarChar(255)
  companionsCount  Int       @default(0) @map("companions_count")
  createdBy        String    @map("created_by") @db.VarChar(20)
  createdByStaffId Int?      @map("created_by_staff_id")
  offerWifi        Boolean   @default(false) @map("offer_wifi")
  wifiRequested    Boolean   @default(false) @map("wifi_requested")
  notifyOnCheckin  Boolean   @default(true) @map("notify_on_checkin")
  groupId          Int?      @map("group_id")
  area             String?   @db.VarChar(100)
  building         String?   @db.VarChar(100)
  floor            String?   @db.VarChar(20)
  room             String?   @db.VarChar(50)
  vehiclePlate     String?   @map("vehicle_plate") @db.VarChar(20)
  notes            String?   @db.Text
  approvedBy       Int?      @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  rejectedAt       DateTime? @map("rejected_at")
  rejectedReason   String?   @map("rejected_reason") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  visitor         Visitor                @relation(fields: [visitorId], references: [id])
  hostStaff       Staff?                 @relation("AppointmentHost", fields: [hostStaffId], references: [id])
  visitPurpose    VisitPurpose           @relation(fields: [visitPurposeId], references: [id])
  department      Department             @relation(fields: [departmentId], references: [id])
  createdByStaff  Staff?                 @relation("AppointmentCreatedBy", fields: [createdByStaffId], references: [id])
  approvedByStaff Staff?                 @relation("AppointmentApprovedBy", fields: [approvedBy], references: [id])
  group           AppointmentGroup?      @relation(fields: [groupId], references: [id])
  companions      AppointmentCompanion[]
  equipment       AppointmentEquipment[]
  statusLogs      AppointmentStatusLog[]
  visitEntries    VisitEntry[]

  @@index([visitorId])
  @@index([hostStaffId])
  @@index([departmentId])
  @@index([status])
  @@index([dateStart])
  @@index([visitPurposeId])
  @@index([groupId])
  @@map("appointments")
}

model VisitEntry {
  id              Int       @id @default(autoincrement())
  entryCode       String    @unique @map("entry_code") @db.VarChar(30)
  appointmentId   Int?      @map("appointment_id")
  visitorId       Int       @map("visitor_id")
  status          String    @db.VarChar(30)
  purpose         String?   @db.VarChar(200)
  visitType       String?   @map("visit_type") @db.VarChar(30)
  hostStaffId     Int?      @map("host_staff_id")
  departmentId    Int?      @map("department_id")
  checkinAt       DateTime  @map("checkin_at")
  checkinChannel  String    @map("checkin_channel") @db.VarChar(20)
  checkoutAt      DateTime? @map("checkout_at")
  checkoutBy      Int?      @map("checkout_by")
  area            String    @db.VarChar(100)
  building        String    @db.VarChar(100)
  floor           String    @db.VarChar(20)
  room            String?   @db.VarChar(50)
  slipPrinted     Boolean?  @map("slip_printed")
  wifiUsername    String?   @map("wifi_username") @db.VarChar(50)
  wifiPassword    String?   @map("wifi_password") @db.VarChar(50)
  idMethod        String?   @map("id_method") @db.VarChar(30)
  servicePointId  Int?      @map("service_point_id")
  facePhotoPath   String?   @map("face_photo_path") @db.VarChar(255)
  companionsCount Int       @default(0) @map("companions_count")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id])
  visitor         Visitor       @relation(fields: [visitorId], references: [id])
  hostStaff       Staff?        @relation("VisitEntryHost", fields: [hostStaffId], references: [id])
  department      Department?   @relation(fields: [departmentId], references: [id])
  checkoutByStaff Staff?        @relation("VisitEntryCheckoutBy", fields: [checkoutBy], references: [id])
  servicePoint    ServicePoint? @relation(fields: [servicePointId], references: [id])

  @@index([appointmentId])
  @@index([visitorId])
  @@index([status])
  @@index([checkinAt])
  @@index([departmentId])
  @@index([servicePointId])
  @@map("visit_entries")
}

model AppointmentCompanion {
  id            Int       @id @default(autoincrement())
  appointmentId Int       @map("appointment_id")
  firstName     String    @map("first_name") @db.VarChar(100)
